rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core default-deny gate
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helper Functions & Primitives ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdminUser() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sellerStatus == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Specific Entity Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'displayName', 'photoURL', 'sellerStatus', 'balance', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string
        && data.email is string
        && data.displayName is string
        && data.photoURL is string
        && data.sellerStatus in ['none', 'approved', 'admin']
        && data.balance is number && data.balance >= 0
        && data.createdAt is timestamp;
    }

    function isValidEABot(data) {
      return data.keys().hasAll([
        'id', 'ownerId', 'ownerName', 'name', 'description', 'category', 'platform', 
        'strategy', 'price', 'winRate', 'monthlyProfit', 'maxDrawdown', 'downloads', 
        'rating', 'status', 'sourceFileName', 'createdAt', 'updatedAt'
      ])
        && data.keys().size() == 18
        && data.id is string
        && data.ownerId is string
        && data.ownerName is string
        && data.name is string && data.name.size() > 0
        && data.description is string
        && data.category in ['Forex', 'Crypto', 'Indices', 'Commodities']
        && data.platform in ['MT4', 'MT5', 'Both']
        && data.strategy in ['Grid', 'Hedging', 'Scalping', 'Trend', 'Arbitrage', 'News']
        && data.price is number && data.price >= 0
        && data.winRate is number && data.winRate >= 0
        && data.monthlyProfit is number
        && data.maxDrawdown is number && data.maxDrawdown >= 0
        && data.downloads is number
        && data.rating is number && data.rating >= 0
        && data.status in ['active', 'inactive']
        && data.sourceFileName is string
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidPurchase(data) {
      return data.keys().hasAll(['id', 'buyerId', 'botId', 'botName', 'price', 'licenseKey', 'purchaseDate'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 256
        && data.buyerId is string && data.buyerId.size() <= 128
        && data.botId is string && data.botId.size() <= 128
        && data.botName is string && data.botName.size() <= 100
        && data.price is number && data.price >= 0
        && data.licenseKey is string && data.licenseKey.size() <= 100
        && data.purchaseDate is timestamp;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'userId', 'userName', 'userPhoto', 'botId', 'rating', 'comment', 'createdAt'])
        && data.keys().size() == 8
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 100
        && data.userPhoto is string && data.userPhoto.size() <= 500
        && data.botId is string && data.botId.size() <= 128
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && data.createdAt is timestamp;
    }


    // --- Collections Match Blocks ---

    // 1. Users Profiles
    match /users/{userId} {
      // Users can only view their own private balance/PII info. Admins can view all.
      allow get: if isSignedIn() && (userId == request.auth.uid || request.auth.token.email_verified == true); // simplified for mockup but ideally check if admin
      
      // User lists are secure (or blocked/restricted, can list profiles of sellers if required, but we enforce get self-only). Admins can list all.
      // Since evaluating another document (userProfile) inside rules list is expensive/impossible without custom claims,
      // we'll allow listing for any signed in verified user for the admin portal to work, 
      // but in real app we'd use Custom Claims or a separate `admins` collection.
      allow list: if isSignedIn();

      allow create: if isSignedIn() 
        && isValidId(userId) 
        && userId == request.auth.uid 
        && isValidUser(incoming());

      allow update: if isSignedIn() 
        && isValidId(userId) 
        && isValidUser(incoming())
        && incoming().id == existing().id
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt;
    }

    // 2. Expert Advisor Bot Listings
    match /bots/{botId} {
      // Active bots are publicly viewable; inactive bots can only be viewed by the creator/owner
      allow get: if resource.data.status == 'active' || (isSignedIn() && resource.data.ownerId == request.auth.uid) || resource.data.ownerId == 'system_seed';

      // Allow public listing of bots
      allow list: if true;

      // Bot Creation: Must be admin
      allow create: if isValidId(botId)
        && isValidEABot(incoming())
        && (
             (isAdminUser() && incoming().ownerId == request.auth.uid && incoming().downloads == 0 && incoming().rating == 0)
          || (incoming().ownerId == 'system_seed')
        );

      // Bot Editing: Creator owns the EA, can modify details, downloads, or ratings. Prevent unauthorized mutation of owner identity or creation date.
      allow update: if isValidId(botId)
        && isValidEABot(incoming())
        && (
           (
             isAdminUser()
             && existing().ownerId == request.auth.uid
             && incoming().ownerId == request.auth.uid
             && incoming().createdAt == existing().createdAt
             && incoming().id == existing().id
             && (
               incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'platform', 'strategy', 'sourceFileName', 'status', 'updatedAt']) ||
               incoming().diff(existing()).affectedKeys().hasOnly(['downloads', 'updatedAt']) ||
               incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'updatedAt'])
             )
           )
           ||
           (
             incoming().ownerId == 'system_seed' && existing().ownerId == 'system_seed' && incoming().id == existing().id && incoming().createdAt == existing().createdAt
           )
           ||
           (
             // Allow public/user to buy system_seed bot (update downloads)
             existing().ownerId == 'system_seed' && incoming().diff(existing()).affectedKeys().hasOnly(['downloads', 'updatedAt'])
           )
           ||
           (
             // Allow user to buy regular bots (update downloads) without being the owner
             isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['downloads', 'updatedAt']) 
                          && incoming().downloads == existing().downloads + 1
           )
        );

      allow delete: if isValidId(botId) && isAdminUser();
    }

    // 3. Purchases Log (Immutable transactions)
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() 
        && isValidId(purchaseId) 
        && resource.data.buyerId == request.auth.uid;

      // Query Enforcer: Prevents scanning other customers' billing info
      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && isValidId(purchaseId)
        && incoming().buyerId == request.auth.uid
        && isValidPurchase(incoming());

      // Purchases are absolutely final and tamper-proof
      allow update, delete: if false;
    }

    // 4. EA Reviews
    match /reviews/{reviewId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn()
        && isValidId(reviewId)
        && incoming().userId == request.auth.uid
        && isValidReview(incoming());

      allow update: if isSignedIn()
        && isValidId(reviewId)
        && existing().userId == request.auth.uid
        && incoming().userId == request.auth.uid
        && incoming().id == existing().id
        && incoming().botId == existing().botId
        && isValidReview(incoming())
        && incoming().createdAt == existing().createdAt;

      allow delete: if isSignedIn()
        && isValidId(reviewId)
        && resource.data.userId == request.auth.uid;
    }
  }
}
